---
import ExternalLinks from "@/components/ExternalLinks.astro";
import type { TimelineItem } from "@/data/timeline";

type Props = {
  item: TimelineItem;
  index: number;
};

const { item, index } = Astro.props;
const dateLabel = item.to ? `${item.from} / ${item.to}` : `${item.from} / active`;
---

<article class="project-card">
  <header>
    <p class="card-index">{String(index + 1).padStart(2, "0")}</p>
    <span class="tag" data-category={item.category}>[{item.category}]</span>
  </header>
  <h3>{item.title}</h3>
  <p class="caption">{item.caption}</p>
  <p class="card-body">{item.description[0]}</p>
  <footer>
    <span>{dateLabel}</span>
    <ExternalLinks links={item.links} />
  </footer>
</article>
