---
type Props = {
  id?: string;
  eyebrow?: string;
  title?: string;
  href?: string;
  linkLabel?: string;
};

const { id, eyebrow, title, href, linkLabel } = Astro.props;
---

<header class="section-header">
  <div>
    {eyebrow && <p class="eyebrow" data-section-eyebrow={id}>{eyebrow}</p>}
    {title && <h2 id={id}>{title}</h2>}
  </div>
  {href && linkLabel && <a class="section-link" href={href}>{linkLabel}</a>}
</header>
