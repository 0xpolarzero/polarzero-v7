---
import octicons from "@primer/octicons";
import { NAV } from "@/data/nav";
import { PROFILE } from "@/data/profile";
import { SOCIALS } from "@/data/socials";

const socialIcons = {
  Email: octicons.mail.toSVG({ "aria-hidden": "true", class: "sidebar-link-icon", height: 14, width: 14 }),
  GitHub: octicons["mark-github"].toSVG({ "aria-hidden": "true", class: "sidebar-link-icon", height: 14, width: 14 }),
  Twitter: octicons.mention.toSVG({ "aria-hidden": "true", class: "sidebar-link-icon", height: 14, width: 14 }),
};
---

<aside class="sidebar">
  <a class="skip-link" href="#content">skip to content</a>

  <nav class="sidebar-block" aria-label="Primary navigation">
    <ul class="nav-list sidebar-primary-nav">
      {NAV.map((item) => <li><a data-nav-link href={item.href}>[{item.label}]</a></li>)}
    </ul>
  </nav>

  <div class="sidebar-separator" aria-hidden="true"></div>

  <div class="sidebar-block">
    <ul class="nav-list">
      {
        SOCIALS.map((social) => (
          <li>
            <a
              href={social.href}
              rel="noreferrer"
              target={social.href.startsWith("mailto:") ? undefined : "_blank"}
            >
              <span set:html={socialIcons[social.label]} />
              [{social.label}]
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="sidebar-separator" aria-hidden="true"></div>

  <div class="sidebar-block">
    <dl class="kv-list">
      <div>
        <dt>timezone</dt>
        <dd>{PROFILE.timezone}</dd>
      </div>
    </dl>
  </div>

  <div class="sidebar-separator" aria-hidden="true"></div>

  <div class="sidebar-block">
    <button
      class="theme-toggle"
      type="button"
      aria-label="Switch to dark mode"
      aria-pressed="false"
      data-theme-toggle
    >
      <span aria-hidden="true" data-theme-icon>◐</span>
      <span data-theme-label>[dark]</span>
    </button>
  </div>
</aside>

<script>
  const themeToggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
  const themeLabel = document.querySelector<HTMLElement>("[data-theme-label]");
  const themeIcon = document.querySelector<HTMLElement>("[data-theme-icon]");
  const themeColor = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
  const storageKey = "polarzero.theme";

  const setTheme = (theme: "light" | "dark") => {
    const isDark = theme === "dark";

    document.documentElement.dataset.theme = theme;

    try {
      localStorage.setItem(storageKey, theme);
    } catch {
      // Theme still updates for the current page when storage is unavailable.
    }

    themeToggle?.setAttribute("aria-pressed", String(isDark));
    themeToggle?.setAttribute("aria-label", `Switch to ${isDark ? "light" : "dark"} mode`);

    if (themeLabel) {
      themeLabel.textContent = isDark ? "[light]" : "[dark]";
    }

    if (themeIcon) {
      themeIcon.textContent = isDark ? "◑" : "◐";
    }

    themeColor?.setAttribute("content", isDark ? "#d96f31" : "#f97316");
  };

  const currentTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
  setTheme(currentTheme);

  themeToggle?.addEventListener("click", () => {
    setTheme(document.documentElement.dataset.theme === "dark" ? "light" : "dark");
  });
</script>
