---
import octicons from "@primer/octicons";
import { NAV } from "@/data/nav";
import { PROFILE } from "@/data/profile";
import { SOCIALS } from "@/data/socials";

const socialIcons = {
  Email: octicons.mail.toSVG({ "aria-hidden": "true", class: "sidebar-link-icon", height: 14, width: 14 }),
  GitHub: octicons["mark-github"].toSVG({ "aria-hidden": "true", class: "sidebar-link-icon", height: 14, width: 14 }),
  Twitter: octicons.mention.toSVG({ "aria-hidden": "true", class: "sidebar-link-icon", height: 14, width: 14 }),
};
---

<aside class="sidebar">
  <a class="skip-link" href="#content">skip to content</a>

  <nav class="sidebar-block" aria-label="Primary navigation">
    <ul class="nav-list sidebar-primary-nav">
      {NAV.map((item) => <li><a data-nav-link href={item.href}>[{item.label}]</a></li>)}
    </ul>
  </nav>

  <div class="sidebar-separator" aria-hidden="true"></div>

  <div class="sidebar-block">
    <ul class="nav-list">
      {
        SOCIALS.map((social) => (
          <li>
            <a
              href={social.href}
              rel="noreferrer"
              target={social.href.startsWith("mailto:") ? undefined : "_blank"}
            >
              <span set:html={socialIcons[social.label]} />
              [{social.label}]
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="sidebar-separator" aria-hidden="true"></div>

  <div class="sidebar-block">
    <dl class="kv-list">
      <div>
        <dt>timezone</dt>
        <dd>{PROFILE.timezone}</dd>
      </div>
    </dl>
  </div>
</aside>
