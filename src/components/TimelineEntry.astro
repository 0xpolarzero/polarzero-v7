---
import ExternalLinks from "@/components/ExternalLinks.astro";
import type { TimelineItem } from "@/data/timeline";

type Props = {
  item: TimelineItem;
  compact?: boolean;
};

const { item, compact = false } = Astro.props;
const dateLabel = item.to ? `${item.from} → ${item.to}` : `${item.from} → now`;
---

<article class:list={["timeline-entry", { compact }]}>
  <header>
    <div>
      <p class="meta-row">
        <span>{dateLabel}</span>
        <span class="tag" data-category={item.category}>[{item.category}]</span>
      </p>
      <h3>{item.title}</h3>
    </div>
    <ExternalLinks links={item.links} />
  </header>
  <p class="caption">{item.caption}</p>
  {
    !compact && (
      <ul>
        {item.description.map((line) => (
          <li>{line}</li>
        ))}
      </ul>
    )
  }
</article>
