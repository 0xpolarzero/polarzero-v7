---
import "@/styles/global.css";

const {
  title = "polarzero",
  description = "Front-End Engineer / Creative Technologist — projects, research, writing, and technical notes.",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://polarzero.xyz").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f97316" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="polarzero agent context" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    <script is:inline>
      const storedTheme = (() => {
        try {
          return localStorage.getItem("polarzero.theme");
        } catch {
          return null;
        }
      })();
      const preferredTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
      const theme = storedTheme === "light" || storedTheme === "dark" ? storedTheme : preferredTheme;

      document.documentElement.dataset.theme = theme;
      document
        .querySelector('meta[name="theme-color"]')
        ?.setAttribute("content", theme === "dark" ? "#d96f31" : "#f97316");
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
