---
import PinnedRepoCard from "@/components/PinnedRepoCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import Sidebar from "@/components/Sidebar.astro";
import TimelineEntry from "@/components/TimelineEntry.astro";
import pinnedRepos from "@/data/pinned-repos.json";
import { PROFILE } from "@/data/profile";
import { TIMELINE, type TimelineCategory } from "@/data/timeline";
import BaseLayout from "@/layouts/BaseLayout.astro";

const activityFilters: Array<TimelineCategory | "all"> = [
  "all",
  "work",
  "experiments",
  "research",
  "writing",
  "education",
];
---

<BaseLayout title="polarzero — research + build">
  <div class="page-frame" aria-hidden="true"></div>
  <div class="site-shell">
    <Sidebar />

    <main id="content" class="content">
      <section id="profile" class="hero section-block" aria-labelledby="profile-title">
        <div class="hero-copy">
          <h1 id="profile-title">polarzero</h1>
          <p class="subtitle">{PROFILE.title}</p>

          <div class="manifesto">
            {PROFILE.summary.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
      </section>

      <section id="pinned" class="section-block" aria-label="Pinned">
        <SectionHeader
          eyebrow="Pinned"
          href="#activity"
          linkLabel="all activity →"
        />

        <div class="pinned-repo-grid">
          {pinnedRepos.repos.map((repo) => <PinnedRepoCard repo={repo} />)}
        </div>
      </section>

      <section id="activity" class="section-block" aria-labelledby="activity-title">
        <SectionHeader id="activity-title" eyebrow="All" title="Activity" />

        <div class="activity-filters" aria-label="Activity filters">
          {
            activityFilters.map((filter) => (
              <button
                aria-pressed={filter === "all" ? "true" : "false"}
                class="activity-filter"
                data-filter={filter}
                type="button"
              >{filter}</button>
            ))
          }
        </div>

        <div class="timeline">
          {
            TIMELINE.map((group) => (
              <section class="timeline-year" aria-labelledby={`year-${group.year}`}>
                <h3 id={`year-${group.year}`}>{group.year}</h3>
                <div class="timeline-stack">
                  {group.items.map((item) => <TimelineEntry item={item} />)}
                </div>
              </section>
            ))
          }
        </div>
      </section>

      <script>
        const filters = Array.from(document.querySelectorAll<HTMLButtonElement>(".activity-filter"));
        const entries = Array.from(document.querySelectorAll<HTMLElement>(".timeline-entry"));
        const years = Array.from(document.querySelectorAll<HTMLElement>(".timeline-year"));
        const status = document.querySelector<HTMLElement>('[data-section-eyebrow="activity-title"]');
        const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]"));
        const sections = navLinks
          .map((link) => document.querySelector<HTMLElement>(link.hash))
          .filter((section): section is HTMLElement => Boolean(section));

        const setCurrentSection = (id: string) => {
          navLinks.forEach((link) => {
            if (link.hash === `#${id}`) {
              link.setAttribute("aria-current", "true");
            } else {
              link.removeAttribute("aria-current");
            }
          });
        };

        const applyFilter = (filter: string) => {
          filters.forEach((button) => {
            button.setAttribute("aria-pressed", String(button.dataset.filter === filter));
          });

          if (status) {
            status.textContent = filter[0].toUpperCase() + filter.slice(1);
          }

          entries.forEach((entry) => {
            entry.hidden = filter !== "all" && entry.dataset.category !== filter;
          });

          years.forEach((year) => {
            year.hidden = !year.querySelector(".timeline-entry:not([hidden])");
          });
        };

        filters.forEach((button) => {
          button.addEventListener("click", () => {
            applyFilter(button.dataset.filter ?? "all");
          });
        });

        if (sections.length > 0) {
          const updateCurrentSection = () => {
            const marker = window.scrollY + window.innerHeight * 0.35;
            const current = sections.findLast((section) => section.offsetTop <= marker) ?? sections[0];

            setCurrentSection(current.id);
          };

          updateCurrentSection();
          window.addEventListener("scroll", updateCurrentSection, { passive: true });
          window.addEventListener("resize", updateCurrentSection);
        }
      </script>

      <footer class="site-footer">
        <span>...</span>
      </footer>
    </main>
  </div>
</BaseLayout>
